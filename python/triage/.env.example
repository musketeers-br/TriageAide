FHIR_BASE_URL=http://iris:52773/fhir/r4
FHIR_USER=_SYSTEM
FHIR_PASS=SYS

# LLM Provider: "openai" (default) or "ollama"
LLM_PROVIDER=openai
# LLM_MODEL: model name (default: gpt-4o-mini for openai, qwen3.5:0.8b for ollama)
#LLM_MODEL=qwen3.5:0.8b
# Ollama base URL (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434

OPENAI_API_KEY=your-openai-api-key-here
LOG_LEVEL=DEBUG
LLM_CACHE=off
#LLM_CACHE_DB_PATH=~/.cache/langchain_cache.db
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=triage-aide
LANGSMITH_TRACING=true

# Voice UI tab visibility (voice bridge still runs on :8003 for testing)
ENABLE_VOICE_UI=false

# ElevenLabs Voice Integration (roadmap — see doc/elevenlabs-integration.md)
# Generate a strong random secret (e.g.: openssl rand -hex 32)
# IMPORTANT: Set this ONLY in .env, NOT in docker-compose.yml environment: section.
# The docker-compose environment: key takes precedence over env_file: and will
# silently override this value, causing 401 Unauthorized errors.
VOICE_BRIDGE_SECRET=your-voice-bridge-secret-here
# ElevenLabs agent ID (from Conversational AI dashboard)
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
# ElevenLabs widget embed ID (optional, for iframe embed)
ELEVENLABS_WIDGET_ID=your-elevenlabs-widget-id
# Public URL of the voice bridge (for ElevenLabs Custom LLM config and UI display)
# Use ngrok for local dev: ngrok http 8003
VOICE_BRIDGE_URL=https://your-ngrok-or-public-url
