FHIR_BASE_URL=http://iris:52773/fhir/r4
FHIR_USER=_SYSTEM
FHIR_PASS=SYS
OPENAI_API_KEY=your-openai-api-key-here
LOG_LEVEL=DEBUG
LLM_CACHE=off
#LLM_CACHE_DB_PATH=~/.cache/langchain_cache.db
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=triage-aide
LANGSMITH_TRACING=true

# --- Vector Search RAG (clinical_reasoning_server + ingest_knowledge.py) ---
# Master switch — set to false to run the clinical assessment without RAG (A/B testing)
RAG_ENABLED=true
# Auto-ingest the knowledge base on first container boot (downloads the fedmml-ed-triage
# dataset, embeds via the configured provider, and stores in IRIS). Set to false to skip.
INGEST_KNOWLEDGE=true
# Embedding provider: openai (text-embedding-3-small, 1536 dims) or ollama (nomic-embed-text, 768 dims)
# IMPORTANT: the same provider/model MUST be used for ingestion and querying.
EMBEDDINGS_PROVIDER=openai
#EMBEDDINGS_MODEL=text-embedding-3-small
#OLLAMA_BASE_URL=http://ollama:11434
# Retrieval tuning: how many similar cases to fetch and the minimum cosine similarity
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.50
# Hybrid search: restrict retrieval to cases within +/- N years of the patient's age (0 = off)
RAG_AGE_WINDOW=0
# IRIS DB-API connection (defaults work inside docker compose)
IRIS_HOST=iris
IRIS_PORT=1972
IRIS_NAMESPACE=USER
IRIS_USERNAME=_SYSTEM
IRIS_PASSWORD=SYS

# Voice UI tab visibility (voice bridge still runs on :8003 for testing)
ENABLE_VOICE_UI=false

# ElevenLabs Voice Integration (roadmap — see doc/elevenlabs-integration.md)
# Generate a strong random secret (e.g.: openssl rand -hex 32)
# IMPORTANT: Set this ONLY in .env, NOT in docker-compose.yml environment: section.
# The docker-compose environment: key takes precedence over env_file: and will
# silently override this value, causing 401 Unauthorized errors.
VOICE_BRIDGE_SECRET=your-voice-bridge-secret-here
# ElevenLabs agent ID (from Conversational AI dashboard)
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id
# ElevenLabs widget embed ID (optional, for iframe embed)
ELEVENLABS_WIDGET_ID=your-elevenlabs-widget-id
# Public URL of the voice bridge (for ElevenLabs Custom LLM config and UI display)
# Use ngrok for local dev: ngrok http 8003
VOICE_BRIDGE_URL=https://your-ngrok-or-public-url
